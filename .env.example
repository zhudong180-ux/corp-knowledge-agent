# LLM 模式: real | mock
LLM_MODE=real

# LLM 配置（OpenAI 兼容协议）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat

# Embedding 配置（本地模型名）
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 数据路径
DATA_DIR=./data
DOCS_DIR=./data/docs
SQLITE_PATH=./data/employees.db
GRAPH_PATH=./data/graph.json

# Agent 行为
MAX_REACT_STEPS=3
MAX_REFLECTIONS=2